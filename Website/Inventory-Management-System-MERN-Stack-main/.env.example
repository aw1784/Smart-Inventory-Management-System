# JWT (must match across api-gateway and auth-service)
JWT_SECRET=replace-me-with-a-strong-secret
JWT_EXPIRES_IN=1d

# Service ports
GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
PRODUCT_SERVICE_PORT=4002
ORDER_SERVICE_PORT=4003
INVENTORY_SERVICE_PORT=4004
STATISTICS_SERVICE_PORT=4005

# Service URLs (used by the api-gateway)
AUTH_SERVICE_URL=http://localhost:4001
PRODUCT_SERVICE_URL=http://localhost:4002
ORDER_SERVICE_URL=http://localhost:4003
INVENTORY_SERVICE_URL=http://localhost:4004
STATISTICS_SERVICE_URL=http://localhost:4005

# MongoDB URIs (each service has its own database)
AUTH_MONGO_URI=mongodb://localhost:27017/inventory_auth
PRODUCT_MONGO_URI=mongodb://localhost:27017/inventory_products
ORDER_MONGO_URI=mongodb://localhost:27017/inventory_orders
INVENTORY_MONGO_URI=mongodb://localhost:27017/inventory_inventory
STATISTICS_MONGO_URI=mongodb://localhost:27017/inventory_statistics
